{
  // --- TypeScript: use the workspace TS (6.0.3), not the editor's bundled one ---
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  // Give the language server more headroom so suggestions stay responsive
  "typescript.tsserver.maxTsServerMemory": 4096,

  // --- Auto-imports ---
  "typescript.suggest.autoImports": true,
  "typescript.preferences.includePackageJsonAutoImports": "auto",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.importModuleSpecifier": "non-relative",

  // --- Stop the editor from crawling 33k+ node_modules files (huge perf win) ---
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.expo/**": true,
    "**/.git/**": true,
    "**/dist/**": true,
    "**/ios/**": true,
    "**/android/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.expo": true,
    "**/dist": true,
    "**/ios": true,
    "**/android": true,
    "**/bun.lock": true
  },

  // --- Existing on-save actions ---
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.sortMembers": "explicit"
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib"
}
